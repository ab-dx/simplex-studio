fact_loop:
Label: 'fact_loop'
Mnemonic: '(null)'
Immediate: '(null)'
    ;  Stop if n == 0 
    ldc n
Label: ''
Mnemonic: 'ldc'
Immediate: 'n'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    brz end_fact
Label: ''
Mnemonic: 'brz'
Immediate: 'end_fact'

    ;  Setup Multiplication (prod = 0) 
    ldc 0
Label: ''
Mnemonic: 'ldc'
Immediate: '0'
    ldc prod
Label: ''
Mnemonic: 'ldc'
Immediate: 'prod'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  Setup Multiplication (mul_a = result) 
    ldc result
Label: ''
Mnemonic: 'ldc'
Immediate: 'result'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc mul_a
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_a'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  Setup Multiplication (mul_b = n) 
    ldc n
Label: ''
Mnemonic: 'ldc'
Immediate: 'n'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc mul_b
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_b'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

mul_loop:
Label: 'mul_loop'
Mnemonic: '(null)'
Immediate: '(null)'
    ;  Stop adding if mul_b == 0 
    ldc mul_b
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_b'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    brz end_mul
Label: ''
Mnemonic: 'brz'
Immediate: 'end_mul'

    ;  prod = prod + mul_a 
    ldc prod
Label: ''
Mnemonic: 'ldc'
Immediate: 'prod'
    ldnl 0      ; A = prod
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc mul_a
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_a'
    ldnl 0      ; A = mul_a, B = prod
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    add         ; A = mul_a + prod
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldc prod    ; A = addr(prod), B = mul_a + prod
Label: ''
Mnemonic: 'ldc'
Immediate: 'prod'
    stnl 0      ; prod = B
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  mul_b = mul_b - 1 
    ldc mul_b
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_b'
    ldnl 0      ; A = mul_b
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1       ; A = 1, B = mul_b
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    sub         ; A = B - A (mul_b - 1)
Label: ''
Mnemonic: 'sub'
Immediate: '(null)'
    ldc mul_b   ; A = addr(mul_b), B = mul_b - 1
Label: ''
Mnemonic: 'ldc'
Immediate: 'mul_b'
    stnl 0      ; mul_b = B
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    br mul_loop
Label: ''
Mnemonic: 'br'
Immediate: 'mul_loop'

end_mul:
Label: 'end_mul'
Mnemonic: '(null)'
Immediate: '(null)'
    ;  result = prod 
    ldc prod
Label: ''
Mnemonic: 'ldc'
Immediate: 'prod'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc result
Label: ''
Mnemonic: 'ldc'
Immediate: 'result'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  n = n - 1 
    ldc n
Label: ''
Mnemonic: 'ldc'
Immediate: 'n'
    ldnl 0      ; A = n
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1       ; A = 1, B = n
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    sub         ; A = B - A (n - 1)
Label: ''
Mnemonic: 'sub'
Immediate: '(null)'
    ldc n       ; A = addr(n), B = n - 1
Label: ''
Mnemonic: 'ldc'
Immediate: 'n'
    stnl 0      ; n = B
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    br fact_loop
Label: ''
Mnemonic: 'br'
Immediate: 'fact_loop'

end_fact:
Label: 'end_fact'
Mnemonic: '(null)'
Immediate: '(null)'
    HALT
Label: ''
Mnemonic: 'HALT'
Immediate: '(null)'

;  DATA SECTION 
n:
