outer_loop:
Label: 'outer_loop'
Mnemonic: '(null)'
Immediate: '(null)'
    ; pos = 0 
    ldc 0
Label: ''
Mnemonic: 'ldc'
Immediate: '0'
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ; isSorted = 1 
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    ldc isSorted
Label: ''
Mnemonic: 'ldc'
Immediate: 'isSorted'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

inner_loop:
Label: 'inner_loop'
Mnemonic: '(null)'
Immediate: '(null)'
    ; stop if pos == 4
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 4
Label: ''
Mnemonic: 'ldc'
Immediate: '4'
    sub 
Label: ''
Mnemonic: 'sub'
Immediate: '(null)'
    brz end_inner_loop
Label: ''
Mnemonic: 'brz'
Immediate: 'end_inner_loop'

    ; temp = arr[pos]
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc arr
Label: ''
Mnemonic: 'ldc'
Immediate: 'arr'
    add 
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldnl 0      ; A = arr[pos]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'

    ldc temp
Label: ''
Mnemonic: 'ldc'
Immediate: 'temp'
    stnl 0      ; temp = arr[pos]
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ; A = arr[pos+1] 
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    add
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldc arr
Label: ''
Mnemonic: 'ldc'
Immediate: 'arr'
    add
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldnl 0      ; A = arr[pos+1]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'

    ; compare 
    ldc temp
Label: ''
Mnemonic: 'ldc'
Immediate: 'temp'
    ldnl 0      ; A = arr[pos], B = arr[pos+1]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    sub         ; A = arr[pos+1] - arr[pos]
Label: ''
Mnemonic: 'sub'
Immediate: '(null)'
    brlz swap
Label: ''
Mnemonic: 'brlz'
Immediate: 'swap'
    brz skip_swap
Label: ''
Mnemonic: 'brz'
Immediate: 'skip_swap'

skip_swap:
Label: 'skip_swap'
Mnemonic: '(null)'
Immediate: '(null)'
    ; pos++
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    add         ; A = pos + 1
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldc pos     
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    stnl 0      ; pos = pos + 1
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    br inner_loop
Label: ''
Mnemonic: 'br'
Immediate: 'inner_loop'

swap:
Label: 'swap'
Mnemonic: '(null)'
Immediate: '(null)'
    ; ptr = addr(arr[pos])
    ; arr[pos] = arr[pos+1]
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc arr
Label: ''
Mnemonic: 'ldc'
Immediate: 'arr'
    add         ; A = addr(arr[pos])
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    
Label: ''
Mnemonic: '(null)'
Immediate: '(null)'
    ldc ptr
Label: ''
Mnemonic: 'ldc'
Immediate: 'ptr'
    stnl 0      ; ptr = addr(arr[pos])
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ; A = arr[pos+1]
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    add
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldc arr
Label: ''
Mnemonic: 'ldc'
Immediate: 'arr'
    add
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldnl 0      ; A = arr[pos+1]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    
Label: ''
Mnemonic: '(null)'
Immediate: '(null)'
    ; arr[pos] = arr[pos+1]
    ldc ptr
Label: ''
Mnemonic: 'ldc'
Immediate: 'ptr'
    ldnl 0      ; A = addr(arr[pos]), B = arr[pos+1]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    stnl 0      ; arr[pos] = arr[pos+1]
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  arr[pos+1] = temp
    ; ptr = addr(arr[pos+1])
    ldc pos
Label: ''
Mnemonic: 'ldc'
Immediate: 'pos'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    add
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    ldc arr
Label: ''
Mnemonic: 'ldc'
Immediate: 'arr'
    add         ; A = addr(arr[pos+1])
Label: ''
Mnemonic: 'add'
Immediate: '(null)'
    
Label: ''
Mnemonic: '(null)'
Immediate: '(null)'
    ldc ptr
Label: ''
Mnemonic: 'ldc'
Immediate: 'ptr'
    stnl 0      ; ptr = addr(arr[pos+1])
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ; A = temp
    ldc temp
Label: ''
Mnemonic: 'ldc'
Immediate: 'temp'
    ldnl 0      ; A = original arr[pos]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    
Label: ''
Mnemonic: '(null)'
Immediate: '(null)'
    ; arr[pos+1] = original arr[pos]
    ldc ptr
Label: ''
Mnemonic: 'ldc'
Immediate: 'ptr'
    ldnl 0      ; A = addr(arr[pos+1]), B = original arr[pos]
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    stnl 0      ; arr[pos+1] = original arr[pos]
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

    ;  isSorted = 0  
    ldc 0
Label: ''
Mnemonic: 'ldc'
Immediate: '0'
    ldc isSorted
Label: ''
Mnemonic: 'ldc'
Immediate: 'isSorted'
    stnl 0
Label: ''
Mnemonic: 'stnl'
Immediate: '0'

end_inner_loop:
Label: 'end_inner_loop'
Mnemonic: '(null)'
Immediate: '(null)'
    ;  check isSorted == 1 ? 
    ldc isSorted
Label: ''
Mnemonic: 'ldc'
Immediate: 'isSorted'
    ldnl 0
Label: ''
Mnemonic: 'ldnl'
Immediate: '0'
    ldc 1
Label: ''
Mnemonic: 'ldc'
Immediate: '1'
    sub
Label: ''
Mnemonic: 'sub'
Immediate: '(null)'
    brz end_sort ; if isSorted == 1, array is sorted
Label: ''
Mnemonic: 'brz'
Immediate: 'end_sort'

    ; otherwise, run another pass
    br outer_loop
Label: ''
Mnemonic: 'br'
Immediate: 'outer_loop'

end_sort:
Label: 'end_sort'
Mnemonic: '(null)'
Immediate: '(null)'
    HALT
Label: ''
Mnemonic: 'HALT'
Immediate: '(null)'

